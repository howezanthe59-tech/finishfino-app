PORT=4000
NODE_ENV=development

# ==========================================
# Contact Form Email Settings
# ==========================================
# The backend reads these values via dotenv (see src/server.js).
#
# IMPORTANT:
# - Do NOT commit your real `.env` with secrets.
# - Keep API keys in backend env vars only (never in frontend code).
#
# SendGrid API key used by the contact route.
# SENDGRID_API_KEY=your_sendgrid_api_key
#
# Optional timeout for SendGrid send call (milliseconds).
# CONTACT_SEND_TIMEOUT_MS=20000
